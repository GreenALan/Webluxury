# Database — connection string consumed by the app (Prisma)
DATABASE_URL=postgresql://luxury:luxury@localhost:5432/luxury?schema=public

# Database — credentials docker-compose.yml uses to provision the local PG
# container. Override in production and keep them in sync with DATABASE_URL
# above. Defaults match local dev so `pnpm db:dev` works out of the box.
POSTGRES_USER=luxury
POSTGRES_PASSWORD=luxury
POSTGRES_DB=luxury

# JWT
JWT_SECRET=dev-secret-change-me-min-32-bytes-required-here
JWT_EXPIRES_IN=7d

# Tencent Cloud COS (M2 用，先占位)
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_DOMAIN=

# Logging
LOG_LEVEL=debug
NODE_ENV=development
